{
  "version": 2,
  "builds": [
    { "src": "api/proxy.js", "use": "@vercel/node" },
    { "src": "index.html",   "use": "@vercel/static" },
    { "src": "config/content.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/proxy",        "dest": "/api/proxy.js" },
    { "src": "/config/(.*)",      "dest": "/config/$1" },
    { "src": "/(.*)",             "dest": "/index.html" }
  ]
}
